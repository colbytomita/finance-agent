# --- Alpaca (optional — app works in manual mode without it) ---
# Paper trading is the default. Never commit real keys.
ALPACA_API_KEY=
ALPACA_API_SECRET=
# "paper" or "live". Orders are only ever user-initiated; live mode additionally
# requires an explicit per-order confirmation (UI + server).
ALPACA_MODE=paper

# --- Yahoo Finance headless-browser fallback ---
# Yahoo data goes over plain HTTP first; the browser is only a fallback (and the
# news-page scan). Set to false to disable just the browser layer. The connector
# as a whole is toggled in Settings ("Yahoo Finance connector").
# Requires: npx playwright install chromium
YAHOO_BROWSER_ENABLED=true

# --- LLM research agent (optional — falls back to rule-based summaries) ---
# Provider: "anthropic" or "none"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# --- Database ---
DATABASE_PATH=./data/finance-agent.db
